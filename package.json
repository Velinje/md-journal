{
  "name": "md-journal",
  "displayName": "md-journal",
  "description": "Performant Journaling tool Using Markdown",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:md-journal.newDailyEntry",
    "onCommand:md-journal.goToTodaysNote",
    "onCommand:md-journal.refreshEntries"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-journal.newDailyEntry",
        "title": "Journal: New Daily Entry"
      },
      {
        "command": "md-journal.goToTodaysNote",
        "title": "Journal: Go to Today's Note"
      },
      {
        "command": "md-journal.refreshEntries",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "md-journal.refreshEntries",
          "when": "view == md-journal-entries",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "MD Journal",
      "properties": {
        "md-journal.journalPath": {
          "type": "string",
          "default": "",
          "description": "The root path to your journal."
        },
        
        "md-journal.folderStructure": {
          "type": "string",
          "default": "YYYY/MM-DD",
          "description": "The folder structure for your journal entries (e.g., YYYY/MM/DD or YYYY/MM-DD). Use YYYY, MM, DD as placeholders."
        },
        "md-journal.fileHeaderFormat": {
          "type": "string",
          "default": "YYYY-MM-DD HH:mm:ss",
          "description": "The format for the header of a new journal file. Uses YYYY, MM, DD, HH, mm, ss as placeholders."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-journal-sidebar",
          "title": "MD Journal",
          "icon": "$(file)"
        }
      ]
    },
    "views": {
      "md-journal-sidebar": [
        {
          "id": "md-journal-entries",
          "name": "Entries"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2"
  }
}
