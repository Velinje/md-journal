{
  "name": "md-journal",
  "displayName": "md-journal",
  "description": "MD Journal: Keep your journaling simple and versatile. A powerful VS Code extension for seamless Markdown journaling.",
  "version": "0.2.0",
  "publisher": "velinje",
  "repository": {
    "url": "https://github.com/Velinje/md-journal",
    "type": "git",
    "directory": "packages/md-journal"
  },
  "bugs": {
    "url": "https://github.com/Velinje/md-journal/issues"
  },
  "homepage": "https://github.com/Velinje/md-journal",
  "license": "MIT",
  "keywords": [
    "vscode",
    "extension",
    "journal",
    "markdown",
    "md-journal",
    "daily notes",
    "productivity"
  ],
  "author": {
    "name": "Andreas Gillberg",
    "url": "https://github.com/Velinje"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],

  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-journal.newDailyEntry",
        "title": "Journal: New Daily Entry"
      },
      {
        "command": "md-journal.goToTodaysNote",
        "title": "Journal: Go to Today's Note"
      },
      {
        "command": "md-journal.saveAsTemplate",
        "title": "Journal: Save as Template"
      },
      {
        "command": "md-journal.refreshEntries",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "md-journal.refreshEntries",
          "when": "view == md-journal-entries",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "MD Journal",
      "properties": {
        "md-journal.journalPath": {
          "type": "string",
          "default": "",
          "description": "The root path to your journal."
        },
        
        "md-journal.folderStructure": {
          "type": "string",
          "default": "YYYY/MMMM/DD-dddd",
          "description": "The folder structure for your journal entries. Uses YYYY, MMMM, MM, dddd, DD as placeholders."
        },
        "md-journal.fileHeaderFormat": {
          "type": "string",
          "default": "daily dddd YYYY-MM-DD",
          "description": "The format for the header of a new journal file. Uses YYYY, MM, DD, dddd, HH, mm, ss as placeholders."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-journal-sidebar",
          "title": "MD Journal",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "md-journal-sidebar": [
        {
          "id": "md-journal-entries",
          "name": "Entries",
          "icon": "$(notebook)"
        },
        {
          "id": "md-journal-tags",
          "name": "Tags",
          "icon": "$(tag)"
        },
        {
          "id": "md-journal-backlinks",
          "name": "Backlinks",
          "icon": "$(link)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2"
  }
}
