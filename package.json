{
  "name": "md-journal",
  "displayName": "md-journal",
  "description": "MD Journal: Keep your journaling simple and versatile. A powerful VS Code extension for seamless Markdown journaling.",
  "version": "0.6.2",
  "publisher": "fuzzyoutput",
  "repository": {
    "url": "https://github.com/Velinje/md-journal",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/Velinje/md-journal/issues"
  },
  "homepage": "https://github.com/Velinje/md-journal",
  "license": "MIT",
  "keywords": [
    "vscode",
    "extension",
    "journal",
    "markdown",
    "md-journal",
    "daily notes",
    "productivity"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/Velinje"
  },
  "author": {
    "name": "Andreas Gillberg",
    "url": "https://github.com/Velinje"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=20.19.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "md-journal.newDailyEntry",
        "title": "New Daily Entry",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.goToTodaysNote",
        "title": "Go to Today's Note",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.saveAsTemplate",
        "title": "Save as Template",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.refreshEntries",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.searchEntries",
        "title": "Search Journal Entries",
        "icon": "$(search)",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.renameEntry",
        "title": "Rename Journal Entry",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.deleteEntry",
        "title": "Delete Journal Entry",
        "category": "MD Journal"
      },
      {
        "command": "md-journal.setPath",
        "title": "Set Journal Folder",
        "icon": "$(folder-opened)",
        "category": "MD Journal"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "md-journal.refreshEntries",
          "when": "view == md-journal-entries",
          "group": "navigation"
        },
        {
          "command": "md-journal.searchEntries",
          "when": "view == md-journal-entries",
          "group": "navigation"
        },
        {
          "command": "md-journal.setPath",
          "when": "view == md-journal-entries",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "md-journal.saveAsTemplate",
          "when": "view == md-journal-entries && viewItem == file",
          "group": "1_modification"
        },
        {
          "command": "md-journal.renameEntry",
          "when": "view == md-journal-entries && viewItem == file",
          "group": "2_workspace"
        },
        {
          "command": "md-journal.deleteEntry",
          "when": "view == md-journal-entries && viewItem == file",
          "group": "2_workspace"
        }
      ],
      "editor/context": [
        {
          "command": "md-journal.saveAsTemplate",
          "when": "resourceExtname == .md",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "md-journal.newDailyEntry",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "editorTextFocus || !editorTextFocus"
      }
    ],
    "configuration": {
      "title": "MD Journal",
      "properties": {
        "md-journal.journalPath": {
          "type": "string",
          "default": "",
          "description": "The root path to your journal."
        },
        "md-journal.folderStructure": {
          "type": "string",
          "default": "YYYY/MMMM/DD-dddd",
          "description": "The folder structure for your journal entries. Uses YYYY, MMMM, MM, dddd, DD as placeholders."
        },
        "md-journal.fileHeaderFormat": {
          "type": "string",
          "default": "daily dddd YYYY-MM-DD",
          "description": "The format for the header of a new journal file. Uses YYYY, MM, DD, dddd, HH, mm, ss as placeholders."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-journal-sidebar",
          "title": "MD Journal",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "md-journal-sidebar": [
        {
          "id": "md-journal-entries",
          "name": "Entries",
          "icon": "$(notebook)"
        },
        {
          "id": "md-journal-tags",
          "name": "Tags",
          "icon": "$(tag)"
        },
        {
          "id": "md-journal-backlinks",
          "name": "Backlinks",
          "icon": "$(link)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "md-journal-entries",
        "when": "!md-journal.hasJournalPath",
        "contents": "Welcome to MD Journal!\n\nNo journal folder has been configured yet. Make sure to set a folder for your entries. It is recommended to store your journal in a folder that is not inside your workspace, use a cloud synced folder like OneDrive, Google Drive or Dropbox.\n [Change Journal Folder](command:md-journal.setPath)"
      },
      {
        "view": "md-journal-entries",
        "when": "md-journal.hasJournalPath",
        "contents": "Your journal is empty.  Create your first entry to get started.\n\n[Create First Entry](command:md-journal.newDailyEntry)\n\nIt is recommended to store your journal in a folder that is not inside your workspace, avoid using the default folder. Use a cloud synced folder like OneDrive, Google Drive or Dropbox.\n [Change Journal Folder](command:md-journal.setPath)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && rolldown -c rolldown.config.mjs",
    "sandbox": "npm run compile && node scripts/sandbox.js",
    "sandbox:persist": "npm run compile && node scripts/sandbox.js --persist",
    "watch": "npm-run-all -p watch:*",
    "watch:rolldown": "rolldown -c rolldown.config.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && rolldown -c rolldown.config.mjs --minify",
    "vsce-package": "vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:log": "vscode-test > test.log 2>&1",
    "test:perf": "vscode-test --run out/test/performance.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.2.1",
    "npm-run-all": "^4.1.5",
    "rolldown": "^0.15.1",
    "typescript": "^6.0.3"
  }
}